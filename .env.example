# Runtime mode used by all apps.
NODE_ENV=development

# Shared log verbosity for api and worker.
LOG_LEVEL=info

# Public URL where the Next.js app serves local traffic.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Public URL used by the web app to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Public environment label exposed to client-side telemetry.
NEXT_PUBLIC_ENVIRONMENT=development

# Optional public Sentry DSN for browser errors and session replay.
NEXT_PUBLIC_SENTRY_DSN=

# Browser trace sampling rate for Sentry on the web app.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional PostHog capture endpoint for privacy-safe product analytics.
NEXT_PUBLIC_POSTHOG_HOST=

# Optional PostHog project key used by the web analytics provider.
NEXT_PUBLIC_POSTHOG_KEY=

# Optional CSP report collection endpoint for the web app.
CSP_REPORT_URI=

# Enables CSP in report-only mode while policies are tuned in production.
NEXT_PUBLIC_CSP_REPORT_ONLY=true

# Optional NextAuth secret used by the web auth route.
NEXTAUTH_SECRET=

# Local port used by the web app.
WEB_PORT=3001

# Local port used by the API app.
API_PORT=3000

# Comma-separated allowlist of origins that can call the API.
API_CORS_ORIGINS=http://localhost:3001

# Fixed window size for API IP rate limiting in milliseconds.
API_RATE_LIMIT_WINDOW_MS=60000

# Maximum requests per IP allowed during the configured window.
API_RATE_LIMIT_MAX=120

# Maximum requests per API key allowed during the configured window.
API_KEY_RATE_LIMIT_MAX=600

# Login brute-force guard window and maximum failed attempts per IP.
API_LOGIN_RATE_LIMIT_MAX=10
API_LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Inbound webhook DDoS protection.
API_WEBHOOK_RATE_LIMIT_MAX=300
API_WEBHOOK_RATE_LIMIT_TENANT_MULTIPLIER=2
API_WEBHOOK_RATE_LIMIT_WINDOW_MS=60000

# Session cookie name for API browser sessions.
API_AUTH_COOKIE_NAME=bh360_session

# Refresh cookie name used for token rotation.
API_AUTH_REFRESH_COOKIE_NAME=bh360_refresh

# Session lifetime in hours for API auth sessions.
API_AUTH_SESSION_TTL_HOURS=24

# Access token lifetime in minutes.
API_AUTH_TOKEN_TTL_MINUTES=15

# Rotation grace period for API keys and legacy refresh sessions in hours.
API_AUTH_ROTATION_GRACE_HOURS=24

# CSRF token cookie/header names (double-submit strategy).
API_CSRF_COOKIE_NAME=bh360_csrf
API_CSRF_HEADER_NAME=x-csrf-token

# Hard timeout budget applied to API handlers.
API_HANDLER_TIMEOUT_MS=10000

# Maximum JSON payload accepted by the API.
API_JSON_BODY_LIMIT=5mb

# API key prefix emitted in create/rotate operations.
API_KEY_PREFIX=bh360_live

# Enables Secure cookies only in HTTPS environments.
REQUIRE_SECURE_COOKIES=false

# PostgreSQL pooled connection string (PgBouncer/Prisma Accelerate compatible).
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/birthub_cycle1?pgbouncer=true

# Direct PostgreSQL URL used by Prisma Migrate when pgbouncer=true is enabled.
DIRECT_DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/birthub_cycle1

# Explicit connection cap applied to Prisma pooled runtimes.
DATABASE_CONNECTION_LIMIT=10

# Redis connection string used by health checks and BullMQ.
REDIS_URL=redis://localhost:6379

# BullMQ queue name shared by api and worker.
QUEUE_NAME=birthub-cycle1

# Backpressure threshold: pause ingestion when pending jobs reach this amount.
QUEUE_BACKPRESSURE_THRESHOLD=10000

# API session secret used for local bootstrap session signing.
SESSION_SECRET=replace-me-in-production

# MFA issuer shown in authenticator apps.
AUTH_MFA_ISSUER=BirthHub360

# Encryption key used to protect TOTP secrets at rest.
AUTH_MFA_ENCRYPTION_KEY=replace-me-in-production

# TOTP clock skew windows (+/- 30s each).
AUTH_MFA_CLOCK_SKEW_WINDOWS=1

# MFA challenge token lifetime in seconds.
AUTH_MFA_CHALLENGE_TTL_SECONDS=300

# Grace period in days before hard-lock when invoice fails.
BILLING_GRACE_PERIOD_DAYS=3

# Global fallback HMAC secret for signed queue payloads.
JOB_HMAC_GLOBAL_SECRET=replace-me-in-production

# API base URL used in generated links and docs.
WEB_BASE_URL=http://localhost:3001

# Default sender used for transactional emails.
EMAIL_FROM_ADDRESS=noreply@birthhub.local

# Stripe secret key (test mode in local development).
STRIPE_SECRET_KEY=sk_test_replace

# Stripe webhook signing secret (from Stripe dashboard).
STRIPE_WEBHOOK_SECRET=whsec_replace

# Temporary ban window after repeated card decline errors during checkout.
STRIPE_DECLINE_BAN_THRESHOLD=5
STRIPE_TEMP_BAN_SECONDS=900

# Redirect URL after successful checkout.
STRIPE_SUCCESS_URL=http://localhost:3001/billing/success

# Redirect URL when checkout is canceled.
STRIPE_CANCEL_URL=http://localhost:3001/billing/cancel

# Return URL for Stripe Billing Portal.
STRIPE_PORTAL_RETURN_URL=http://localhost:3001/settings/billing

# Worker concurrency for BullMQ processing. Leave empty to auto-scale with CPU count.
WORKER_CONCURRENCY=

# Per-tenant queue ingestion guard to avoid monopolizing workers.
TENANT_QUEUE_RATE_LIMIT_MAX=120
TENANT_QUEUE_RATE_LIMIT_WINDOW_SECONDS=60

# Cache TTL for tenant billing status lookups in worker guard.
BILLING_STATUS_CACHE_TTL_SECONDS=60

# Optional SendGrid API key for external email delivery.
SENDGRID_API_KEY=

# Optional HubSpot private app token.
HUBSPOT_ACCESS_TOKEN=

# HubSpot API base URL.
HUBSPOT_BASE_URL=https://api.hubapi.com

# Timeout used for outbound webhook delivery in milliseconds.
WEBHOOK_TIMEOUT_MS=10000

# Optional pre-signed upload URL for dataset JSONL exports.
DATASET_EXPORT_UPLOAD_URL=

# Optional bearer token used with DATASET_EXPORT_UPLOAD_URL.
DATASET_EXPORT_UPLOAD_TOKEN=

# Optional comma-separated URLs checked by the health endpoint.
EXTERNAL_HEALTHCHECK_URLS=https://example.com/health

# Optional Sentry DSN for API and worker server-side errors.
SENTRY_DSN=

# Optional UptimeRobot API token for deep-health monitor automation.
UPTIMEROBOT_API_TOKEN=

# Optional explicit Sentry environment tag for backend processes.
SENTRY_ENVIRONMENT=development

# Optional auth token used when uploading Sentry source maps from web builds.
SENTRY_AUTH_TOKEN=

# Optional OTLP collector endpoint for API traces.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Logical service name exported by the API OpenTelemetry SDK.
OTEL_SERVICE_NAME=birthub-api
