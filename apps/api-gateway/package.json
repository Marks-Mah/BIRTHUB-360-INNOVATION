{
  "name": "@birthub/api-gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.supported.json",
    "typecheck": "tsc -p tsconfig.supported.json --noEmit",
    "test": "node --import tsx --test \"src/routes/*.test.ts\"",
    "test:contract": "node --import tsx --test \"src/**/*.contract.test.ts\"",
    "lint": "node --import tsx src/scripts/check-conventions.ts"
  },
  "dependencies": {
    "@birthub/queue": "workspace:*",
    "@birthub/shared-types": "workspace:*",
    "@birthub/utils": "workspace:*",
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
