{
  "name": "@birthub/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "billing:sync": "tsx src/modules/billing/sync-plans.ts",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint .",
    "start": "node dist/apps/api/src/server.js",
    "test:auth": "node --import tsx --test tests/auth.test.ts",
    "test:rbac": "node --import tsx --test tests/rbac.test.ts",
    "test:security": "node --import tsx --test tests/security.test.ts",
    "test": "node --import tsx --test tests/**/*.test.ts test/**/*.test.ts",
    "test:isolation": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.2.0",
    "@birthub/agents-core": "workspace:*",
    "@birthub/config": "workspace:*",
    "@birthub/database": "workspace:*",
    "@birthub/logger": "workspace:*",
    "@birthub/workflows-core": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@prisma/instrumentation": "^7.5.0",
    "@sentry/node": "^10.43.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "redlock": "5.0.0-beta.2",
    "stripe": "^20.4.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
