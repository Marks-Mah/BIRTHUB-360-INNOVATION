{
  "title": "Birthub SLO Overview",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "stat",
      "title": "API Availability (5m)",
      "targets": [
        {
          "expr": "1 - (rate(http_requests_total{job='api-gateway',status=~'5..'}[5m]) / clamp_min(rate(http_requests_total{job='api-gateway'}[5m]), 0.001))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Budget Burn (5m)",
      "targets": [
        {
          "expr": "rate(http_requests_total{job='api-gateway',status=~'5..'}[5m]) / clamp_min(rate(http_requests_total{job='api-gateway'}[5m]), 0.001)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p99",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job='api-gateway'}[5m])))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "429 Rate",
      "targets": [
        {
          "expr": "rate(http_requests_total{job='api-gateway',status='429'}[5m])"
        }
      ]
    }
  ]
}
